// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String        @id @default(uuid())
  email         String        @unique
  password      String
  credits       Int           @default(1)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  
  videos        Video[]
  transactions  Transaction[]
  refreshTokens RefreshToken[]
  
  @@index([email])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([token])
}

model Video {
  id              String   @id @default(uuid())
  userId          String
  
  // Input
  url             String
  videoLength     String   @default("medium")
  webhookUrl      String?
  
  // Processing
  status          String   @default("pending")
  jobId           String?  @unique
  progress        Int      @default(0)
  errorMessage    String?
  
  // Output
  scriptData      Json?
  audioUrl        String?
  mp4Url          String?
  squareUrl       String?
  gifUrl          String?
  
  // Viral Score
  viralScore      Float?
  viralTips       Json?
  
  // Metadata
  duration        Int?
  screenshotCount Int?
  metadata        Json?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  completedAt     DateTime?
  
  user     User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  webhooks WebhookLog[]
  
  @@index([userId])
  @@index([status])
  @@index([jobId])
}

model Transaction {
  id                String   @id @default(uuid())
  userId            String
  
  razorpayOrderId   String   @unique
  razorpayPaymentId String?  @unique
  razorpaySignature String?
  
  amount            Int
  credits           Int
  status            String   @default("created")
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([razorpayOrderId])
}

model WebhookLog {
  id            String   @id @default(uuid())
  videoId       String
  
  url           String
  attempts      Int      @default(0)
  maxAttempts   Int      @default(3)
  status        String   @default("pending")
  
  lastAttemptAt DateTime?
  lastResponse  String?
  nextRetryAt   DateTime?
  
  createdAt     DateTime @default(now())
  
  video Video @relation(fields: [videoId], references: [id], onDelete: Cascade)
  
  @@index([videoId])
  @@index([status])
  @@index([nextRetryAt])
}
